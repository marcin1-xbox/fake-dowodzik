name: Budowanie aplikacji Android APK

on:
  push:
    branches:
      - main  # Uruchomi się za każdym razem, gdy wrzucisz zmiany na gałąź main
  workflow_dispatch: # Pozwala też uruchomić proces ręcznie w zakładce Actions

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
    - name: Pobranie kodu z repozytorium
      uses: actions/checkout@v4

    - name: Konfiguracja Node.js
      uses: actions/setup-node@v4
      with:
        node-version: '20'

    - name: Instalacja Cordova
      run: npm install -g cordova

    - name: Konfiguracja środowiska Java (potrzebne do Androida)
      uses: actions/setup-java@v4
      with:
        distribution: 'zulu'
        java-version: '17'

    - name: Konfiguracja Android SDK
      uses: android-actions/setup-android@v3

    - name: Tworzenie projektu Cordova i budowanie APK
      run: |
        # Tworzy tymczasowy projekt Cordova
        cordova create apk-build com.twojadomena.mojaaplikacja MojaAplikacja
        cd apk-build
        
        # Kopiuje Twoje pliki HTML/JSON/XML z głównego katalogu repozytorium do folderu www Cordovy
        cp -r ../* www/ || true
        
        # Dodaje platformę Android i buduje niesygnowane APK (debug)
        cordova platform add android
        cordova build android --debug

    - name: Zapisanie gotowego pliku APK jako artefakt
      uses: actions/upload-artifact@v4
      with:
        name: aplikacja-apk
        path: apk-build/platforms/android/app/build/outputs/apk/debug/app-debug.apk

